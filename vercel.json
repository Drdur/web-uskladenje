{
    "version": 2,
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/widget.js",
            "dest": "/widget.js"
        },
        {
            "src": "/widget.css",
            "dest": "/widget.css"
        },
        {
            "src": "/",
            "dest": "/index.html"
        }
    ]
}